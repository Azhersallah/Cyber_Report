{
    "name": "photo-printer-pro",
    "version": "1.1.0",
    "type": "module",
    "main": "loader.cjs",
    "description": "Professional Photo Printing Tool for print shops",
    "author": {
        "name": "Azher Sallah",
        "email": "azhersallah@gmail.com"
    },
    "publisher": "Azher Sallah",
    "homepage": "https://photo-printer-pro.netlify.app/",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/Azhersallah/photo-printer-pro"
    },
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "electron": "concurrently \"vite\" \"wait-on http://localhost:3000 && electron .\"",
        "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:3000 && electron .\"",
        "electron:build": "vite build && node scripts/generate-icons.cjs && node scripts/encrypt-main.cjs && electron-builder",
        "electron:start": "electron .",
        "build:native": "node-gyp rebuild",
        "build:native:electron": "electron-rebuild -f -w license_checker",
        "rebuild:native": "node-gyp clean && node-gyp rebuild",
        "postinstall": "electron-rebuild -f -w license_checker || echo 'Native module rebuild skipped'"
    },
    "dependencies": {
        "@fontsource/inter": "^5.2.8",
        "@fontsource/noto-kufi-arabic": "^5.2.9",
        "@fontsource/noto-naskh-arabic": "^5.2.10",
        "@google/generative-ai": "^0.24.1",
        "@imgly/background-removal": "^1.7.0",
        "@radix-ui/react-alert-dialog": "^1.1.15",
        "@radix-ui/react-dialog": "^1.1.15",
        "@radix-ui/react-slot": "^1.2.4",
        "autoprefixer": "^10.4.23",
        "bindings": "^1.5.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "docx": "^8.5.0",
        "electron-log": "^5.4.3",
        "electron-updater": "^6.6.2",
        "face-api.js": "^0.22.2",
        "firebase-admin": "^13.6.0",
        "heic2any": "^0.0.4",
        "html2canvas": "^1.4.1",
        "html2pdf.js": "^0.14.0",
        "jspdf": "^4.0.0",
        "lucide-react": "^0.461.0",
        "node-addon-api": "^8.5.0",
        "pdf-lib": "^1.17.1",
        "pixi.js": "^8.15.0",
        "postcss": "^8.5.6",
        "prebuild-install": "^7.1.3",
        "puppeteer-core": "^25.1.0",
        "qrcode.react": "^4.2.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "tailwind-merge": "^3.4.0",
        "winreg": "^1.2.5",
        "ws": "^8.19.0"
    },
    "devDependencies": {
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@types/jest": "^30.0.0",
        "@types/qrcode.react": "^1.0.5",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@vitejs/plugin-react": "^4.3.4",
        "concurrently": "^8.2.2",
        "electron": "^31.0.0",
        "electron-builder": "^24.13.3",
        "electron-rebuild": "^3.2.9",
        "fast-check": "^4.5.3",
        "javascript-obfuscator": "^5.1.0",
        "jest": "^30.2.0",
        "jest-environment-jsdom": "^30.2.0",
        "png-to-ico": "^3.0.1",
        "sharp": "^0.34.5",
        "tailwindcss": "^3.4.19",
        "ts-jest": "^29.4.6",
        "typescript": "^5.7.2",
        "vite": "^6.0.3",
        "wait-on": "^7.2.0"
    },
    "build": {
        "appId": "com.photoprinterpro.app",
        "productName": "Photo Printer Pro",
        "directories": {
            "output": "release"
        },
        "files": [
            "dist/**/*",
            "loader.cjs",
            "main.enc",
            "native/index.cjs",
            "native_build/Release/license_checker.node",
            "trial-manager.enc",
            "package.json"
        ],
        "asar": true,
        "asarUnpack": [
            "node_modules/sharp/**/*",
            "native_build/Release/*.node",
            "native/**/*",
            "main.enc",
            "**/*.enc"
        ],
        "fileAssociations": [
            {
                "ext": "pppro",
                "name": "Photo Printer Pro Project",
                "description": "Photo Printer Pro Project File",
                "icon": "build/file-icon.ico",
                "role": "Editor"
            }
        ],
        "publish": {
            "provider": "github",
            "owner": "Azhersallah",
            "repo": "photo-printer-pro",
            "private": false
        },
        "win": {
            "target": "nsis",
            "icon": "build/icon.ico",
            "publisherName": "Azher Sallah",
            "legalTrademarks": "Photo Printer Pro © 2024 Azher Sallah",
            "requestedExecutionLevel": "asInvoker"
        },
        "mac": {
            "target": "dmg",
            "icon": "build/icon.icns"
        },
        "linux": {
            "target": "AppImage",
            "icon": "build/icon.png"
        },
        "nsis": {
            "oneClick": true,
            "allowToChangeInstallationDirectory": false,
            "installerIcon": "build/icon.ico",
            "uninstallerIcon": "build/icon.ico",
            "installerHeaderIcon": "build/icon.ico",
            "perMachine": false,
            "license": "LICENSE.txt",
            "displayLanguageSelector": false,
            "installerLanguages": [
                "en_US"
            ],
            "shortcutName": "Photo Printer Pro"
        },
        "copyright": "Copyright © 2024 Azher Sallah. All rights reserved."
    }
}
