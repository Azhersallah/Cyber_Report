{
  "name": "cyber-report",
  "version": "1.2.0",
  "type": "module",
  "main": "loader.cjs",
  "description": "Professional Image Reporting and Analysis Tool",
  "author": {
    "name": "Azher Sallah",
    "email": "azhersallah1@gmail.com"
  },
  "publisher": "Azher Sallah",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Azhersallah/Cyber_Report"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "node scripts/electron-dev.cjs",
    "electron:dev": "node scripts/electron-dev.cjs",
    "electron:build": "vite build && node scripts/generate-icons.cjs && electron-builder",
    "electron:start": "electron ."
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/noto-kufi-arabic": "^5.2.9",
    "@fontsource/noto-naskh-arabic": "^5.2.10",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "autoprefixer": "^10.4.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "docx": "^8.5.0",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.6.2",
    "heic2any": "^0.0.4",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.0.0",
    "lucide-react": "^0.461.0",
    "postcss": "^8.5.6",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/qrcode.react": "^1.0.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "fast-check": "^4.5.3",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.19",
    "ts-jest": "^29.4.6",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.cyberreport.app",
    "productName": "Cyber Report",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "loader.cjs",
      "main.cjs",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/sharp/**/*"
    ],
    "fileAssociations": [
      {
        "ext": "cyr",
        "name": "Cyber Report Project",
        "description": "Cyber Report Project File",
        "icon": "build/file-icon.ico",
        "role": "Editor"
      },
      {
        "ext": "ppfree",
        "name": "Cyber Report Project",
        "description": "Cyber Report Project File",
        "icon": "build/file-icon.ico",
        "role": "Editor"
      },
      {
        "ext": "pppro",
        "name": "Cyber Report Project",
        "description": "Cyber Report Project File",
        "icon": "build/file-icon.ico",
        "role": "Editor"
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "Azhersallah",
      "repo": "Cyber_Report",
      "private": false
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "publisherName": "Azher Sallah",
      "legalTrademarks": "Cyber Report © 2024 Azher Sallah",
      "requestedExecutionLevel": "asInvoker"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "perMachine": false,
      "license": "LICENSE.txt",
      "displayLanguageSelector": false,
      "installerLanguages": [
        "en_US"
      ],
      "shortcutName": "Cyber Report"
    },
    "copyright": "Copyright © 2024 Azher Sallah. All rights reserved."
  }
}